1. Exemplo expandido:

# ═══ Sistema Especialista — Diagnóstico Tropical ═══

class SistemaEspecialista:
    def __init__(self, nome):
        self.nome = nome
        self.fatos = set()
        self.regras = []

    def regra(self, sintomas, diagnostico, confianca=1.0):
        self.regras.append({
            'sintomas': set(sintomas),
            'diagnostico': diagnostico,
            'confianca': confianca
        })

    def perguntar(self, sintoma):
        resp = input(f"Você tem {sintoma.replace('_', ' ')}? (s/n): ").strip().lower()

        if resp == 's':
            self.fatos.add(sintoma)
            return True

        return False

    def diagnosticar(self):
        print(f"\n🏥 {self.nome}")
        print("Responda com s (sim) ou n (não).\n")

        # Coleta todos os sintomas
        todos_sintomas = set()

        for r in self.regras:
            todos_sintomas.update(r['sintomas'])

        # Perguntas
        for sintoma in sorted(todos_sintomas):
            self.perguntar(sintoma)

        # Diagnóstico
        print("\n🔍 Analisando sintomas...\n")

        resultados = []

        for r in self.regras:
            match = len(r['sintomas'] & self.fatos)
            total = len(r['sintomas'])

            if match > 0:
                score = (match / total) * r['confianca']
                resultados.append((r['diagnostico'], score, match, total))

        resultados.sort(key=lambda x: -x[1])

        if resultados:
            print("📋 Possíveis diagnósticos:\n")

            for diag, score, match, total in resultados:
                barra = '█' * int(score * 20)
                barra += '░' * (20 - int(score * 20))

                print(f"{barra} {score*100:5.1f}%")
                print(f"➡ {diag} ({match}/{total} sintomas)\n")
        else:
            print("Nenhum diagnóstico encontrado.")

# Criando sistema

